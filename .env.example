# ARGUS Backend - Environment Configuration Template

# Copy this file to .env and update values for your environment.
# WARNING: Never commit .env files to version control!

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://argus:argus@localhost:5432/argus
DB_POOL_SIZE=10

# JWT Authentication
JWT_SECRET=change-me-min-32-chars-please-in-production
JWT_EXPIRES_IN=8h

# MQTT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=fleet/+/telemetry
MQTT_RECONNECT_PERIOD_MS=5000
MQTT_CONNECT_TIMEOUT_MS=10000

# Mapbox Integration
MAPBOX_API_KEY=
MAPBOX_TIMEOUT_MS=10000

# LLM Integration (Groq/Gemini)
LLM_PROVIDER_API_KEY=
LLM_PROVIDER_URL=https://api.groq.com/openai/v1/chat/completions
LLM_PROVIDER_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER_TIMEOUT_MS=15000
# For Gemini, use:
# LLM_PROVIDER_URL=https://generativelanguage.googleapis.com
# LLM_PROVIDER_MODEL=gemini-2.5-flash

# Route Optimization Engine
OPTIMIZATION_ENGINE_URL=http://localhost:8001
OPTIMIZATION_ENGINE_TIMEOUT_MS=20000
SWARM_RECOVERY_TARGET_MS=60000
SWARM_RECOVERY_OPT_TIMEOUT_MS=15000

# Fleet Monitoring
STALE_THRESHOLD_SECONDS=180
OFFLINE_THRESHOLD_SECONDS=600
WATCHDOG_INTERVAL_SECONDS=60

# Telemetry Retention
TELEMETRY_COMPRESS_AFTER_DAYS=7
TELEMETRY_DROP_AFTER_DAYS=90

# Volume Anomaly Detection
LOW_VOLUME_THRESHOLD=0.20
MOVING_AVERAGE_WINDOW_DAYS=7